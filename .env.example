# Open Grid — sample env file.
# Copy to .env.local (gitignored) and fill in real values.
#
#   cp .env.example .env.local
#   sed -i "s|^SESSION_SECRET=.*|SESSION_SECRET=$(openssl rand -hex 32)|" .env.local
#
# scripts/install.sh does the above automatically.

# ── Required in production ───────────────────────────────────────────────────

# HMAC signing key for the og_sid session cookie. Min 16 chars.
# Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-openssl-rand-hex-32

# Comma-separated hostnames allowed for CORS + WebSocket Origin checks.
# In dev with the split Vite + API ports, this is the canvas dev origin.
ALLOWED_ORIGINS=http://localhost:5173

# Set to "production" when deploying. Leave unset for local dev.
# NODE_ENV=production

# ── Ports (per-service) ──────────────────────────────────────────────────────

# API + WebSocket server.
# PORT=4000

# Vite dev server for the web canvas.
# (Set when running the canvas directly; the root `pnpm dev` script wires
#  these for you.)
# PORT=5173

# ── Optional tuning ──────────────────────────────────────────────────────────

# Parent dir for per-session workspace jails. Default: ~/.opengrid-workspaces
# WORKSPACES_ROOT=/var/lib/opengrid

# Max concurrent PTYs across all users (default 64).
# MAX_SESSIONS=64

# Max concurrent browser sessions (default 500).
# MAX_USER_SESSIONS=500

# Where the single-port deployment looks for the prebuilt SPA.
# Defaults to ../opengrid-canvas/dist/public relative to the API server.
# WEB_DIST=/app/opengrid-canvas/dist/public

# Serve the prebuilt SPA from the API server (single-port mode).
# The Docker image sets this to 1 by default.
# SERVE_WEB=1
